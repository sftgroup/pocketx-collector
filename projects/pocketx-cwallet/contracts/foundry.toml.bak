[profile.default]
src = "src"
out = "out"
libs = ["lib"]
solc = "0.8.20"
evm_version = "paris"
optimizer = true
optimizer_runs = 200
via_ir = true

# Increase the number of optimization runs for bytecode size reduction
# IR-based compilation handles stack-too-deep better

# See more config options https://github.com/foundry-rs/foundry/blob/master/crates/config/README.md#all-options
