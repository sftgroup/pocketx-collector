# PocketX Backend — Environment Configuration
# Copy to .env and fill in values

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://pocketx:pocketx@localhost:5432/pocketx_cwallet

# Redis (for rate limiting, session cache, job queues)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# SMS Provider (Twilio / Alibaba Cloud / etc.)
SMS_PROVIDER=console  # 'console' for dev logging, 'twilio' or 'aliyun' for prod
SMS_API_KEY=
SMS_API_SECRET=

# CWallet Internal API
CWALLET_BASE_URL=http://cwallet-internal:8080/api/internal
CWALLET_API_KEY=change-me-cwallet-api-key

# Gas Pool
GAS_POOL_PRIVATE_KEY=
GAS_POOL_ADDRESS=

# Supported Chains
SUPPORTED_CHAINS=eth,polygon,arbitrum,optimism,bsc,base

# Risk Control Defaults
RISK_SINGLE_LIMIT_DEFAULT=10000
RISK_DAILY_LIMIT_DEFAULT=50000
RISK_NEW_USER_LIMIT_DEFAULT=1000
RISK_NEW_USER_HOURS=24

# Signature Strategy
SIG_AUTO_SIGN_MAX=100
SIG_CONFIRM_MIN=100
SIG_CONFIRM_MAX=10000
SIG_APPROVAL_MIN=10000

# Webhook
WEBHOOK_RETRY_MAX=3
WEBHOOK_TIMEOUT_MS=10000

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Block Scanner
BLOCK_SCAN_INTERVAL_MS=12000
BLOCK_SCAN_CONFIRMATIONS=1

# Logging
LOG_LEVEL=debug
